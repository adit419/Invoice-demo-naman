SECRET_KEY=change_me_to_a_long_random_string

DEMO_MODE=true
DEMO_MODE_SHOW_PLACEHOLDER_BANNER=true

# CORS: set to your frontend URL (EC2 IP or domain)
CORS_ORIGIN=http://localhost:3001

# Anthropic / Claude AI (used for Cash AI matching)
ANTHROPIC_API_KEY=sk-ant-...

# Optional: Zoho Books integration
# ZOHO_CLIENT_ID=your_client_id
# ZOHO_CLIENT_SECRET=your_client_secret
# ZOHO_REFRESH_TOKEN=your_refresh_token

# ─── Gmail ingestion ──────────────────────────────────────────────────────────
# WARNING: DO NOT use the production credentials for svc-tools@neoflo.ai when
# running locally. That mailbox is actively polled by the production server, and
# running a second poller against the same account will cause emails to be
# consumed out-of-order or skipped entirely — making the prod pipeline
# inconsistent. Use a personal or sandbox Gmail account for local development.
# ──────────────────────────────────────────────────────────────────────────────
# GMAIL_ENABLED=false
# GMAIL_CLIENT_ID=your_client_id
# GMAIL_CLIENT_SECRET=your_client_secret
# GMAIL_REFRESH_TOKEN=your_refresh_token
# GMAIL_TARGET_EMAIL=your-sandbox@gmail.com   # ← never svc-tools@neoflo.ai locally
# GMAIL_POLL_INTERVAL=30
